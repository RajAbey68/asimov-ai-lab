# ============================================================
# ASIMOV AI — Environment variables
# Copy to .env.local for local development.
# NEVER commit .env.local or .env to source control.
# ============================================================

# Supabase project URL (public — safe to expose to the browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon/public key (public — safe to expose to the browser)
# RLS must be correctly configured before this key is used in client code.
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service-role key (PRIVATE — Edge Functions only, never in client bundles)
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Resend API key for transactional email (PRIVATE — server/edge only)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cal.com embed URL for Board Diagnostic booking widget
CAL_COM_EMBED_URL=https://cal.com/asimov-ai/board-diagnostic
